[sub_resource type="Resource" id="Resource_reward"]
script = ExtResource("12_frag_reward")
fragment_id = &"ep2.compass.frag_4"
key_item_id = &"key.mixed_compass"
frame_slot = 3
art_path = "res://art/compass_frag_4.png"

[sub_resource type="RectangleShape2D" id="RectangleShape2D_walkable"]
size = Vector2(2560, 1440)

[sub_resource type="GDScript" id="GDScript_trigger"]
script/source = "extends Node

func _ready() -> void:
	EventBus.key_item_completed.connect(_on_key_item_completed)

func _on_key_item_completed(key_item_id: StringName) -> void:
	if key_item_id != &\"key.mixed_compass\":
		return
	var btn := get_parent().get_node_or_null(\"ActionButton\")
	if is_instance_valid(btn):
		btn.hide()
"

[node name="Zone4RockFace" type="Node2D"]
script = ExtResource("1")
zone_id = &"ep2.zone_4"

